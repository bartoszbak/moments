// Shared build configuration committed to the repository.
// Local developer secrets can live in Config.xcconfig, which is gitignored.
OPENROUTER_API_KEY = $(inherited)
OPENROUTER_MODEL = openai/gpt-4o-mini

#include? "Config.xcconfig"

INFOPLIST_KEY_OPENROUTER_API_KEY = $(OPENROUTER_API_KEY)
INFOPLIST_KEY_OPENROUTER_MODEL = $(OPENROUTER_MODEL)
