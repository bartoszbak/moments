// Shared build configuration committed to the repository.
// Local developer secrets can live in Config.xcconfig, which is gitignored.
OPENROUTER_API_KEY_TEST = $(inherited)
OPENROUTER_API_KEY_PRODUCTION = $(inherited)
OPENROUTER_API_KEY = $(OPENROUTER_API_KEY_PRODUCTION)
OPENROUTER_API_KEY[config=Debug] = $(OPENROUTER_API_KEY_TEST)
OPENROUTER_MODEL = openai/gpt-4o-mini
REVENUECAT_API_KEY_TEST = $(inherited)
REVENUECAT_API_KEY_PRODUCTION = $(inherited)
REVENUECAT_API_KEY_IOS = $(REVENUECAT_API_KEY_PRODUCTION)
REVENUECAT_API_KEY_IOS[config=Debug] = $(REVENUECAT_API_KEY_TEST)
REVENUECAT_ENTITLEMENT_PREMIUM = Moments Plus
PRIVACY_POLICY_URL =

#include? "Config.xcconfig"

INFOPLIST_KEY_OPENROUTER_API_KEY = $(OPENROUTER_API_KEY)
INFOPLIST_KEY_OPENROUTER_MODEL = $(OPENROUTER_MODEL)
INFOPLIST_KEY_REVENUECAT_API_KEY_IOS = $(REVENUECAT_API_KEY_IOS)
INFOPLIST_KEY_REVENUECAT_ENTITLEMENT_PREMIUM = $(REVENUECAT_ENTITLEMENT_PREMIUM)
INFOPLIST_KEY_PRIVACY_POLICY_URL = $(PRIVACY_POLICY_URL)
